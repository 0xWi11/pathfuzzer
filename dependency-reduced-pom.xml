<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/maven-v4_0_0.xsd">
  <modelVersion>4.0.0</modelVersion>
  <groupId>org.example</groupId>
  <artifactId>path-fuzzer</artifactId>
  <version>1.0-SNAPSHOT</version>
  <build>
    <resources>
      <resource>
        <filtering>true</filtering>
        <directory>src/main/resources</directory>
        <includes>
          <include>**/*.properties</include>
          <include>**/*.xml</include>
        </includes>
      </resource>
      <resource>
        <directory>src/main/resources</directory>
        <excludes>
          <exclude>**/*.properties</exclude>
          <exclude>**/*.xml</exclude>
        </excludes>
      </resource>
    </resources>
    <finalName>${final.jar.name}-${project.version}</finalName>
    <plugins>
      <plugin>
        <artifactId>maven-resources-plugin</artifactId>
        <version>3.3.0</version>
        <configuration>
          <encoding>UTF-8</encoding>
          <propertiesEncoding>UTF-8</propertiesEncoding>
        </configuration>
      </plugin>
      <plugin>
        <artifactId>maven-compiler-plugin</artifactId>
        <version>3.11.0</version>
        <configuration>
          <source>17</source>
          <target>17</target>
          <encoding>UTF-8</encoding>
        </configuration>
      </plugin>
      <plugin>
        <artifactId>maven-shade-plugin</artifactId>
        <version>3.4.1</version>
        <executions>
          <execution>
            <phase>package</phase>
            <goals>
              <goal>shade</goal>
            </goals>
            <configuration>
              <shadedArtifactAttached>false</shadedArtifactAttached>
              <createDependencyReducedPom>true</createDependencyReducedPom>
              <relocations>
                <relocation>
                  <pattern>pzfzr</pattern>
                  <shadedPattern>${shade.package.prefix}</shadedPattern>
                </relocation>
              </relocations>
              <transformers>
                <transformer />
                <transformer>
                  <resource>META-INF/spring.handlers</resource>
                </transformer>
                <transformer>
                  <resource>META-INF/spring.schemas</resource>
                </transformer>
                <transformer>
                  <manifestEntries>
                    <Plugin-Name>${plugin.name}</Plugin-Name>
                  </manifestEntries>
                </transformer>
              </transformers>
              <filters>
                <filter>
                  <artifact>*:*</artifact>
                  <excludes>
                    <exclude>META-INF/*.SF</exclude>
                    <exclude>META-INF/*.DSA</exclude>
                    <exclude>META-INF/*.RSA</exclude>
                    <exclude>META-INF/MANIFEST.MF</exclude>
                  </excludes>
                </filter>
              </filters>
            </configuration>
          </execution>
        </executions>
      </plugin>
      <plugin>
        <artifactId>maven-antrun-plugin</artifactId>
        <version>3.1.0</version>
        <executions>
          <execution>
            <phase>package</phase>
            <goals>
              <goal>run</goal>
            </goals>
            <configuration>
              <target>
                <mkdir />
                <copy />
                <echo />
              </target>
            </configuration>
          </execution>
        </executions>
      </plugin>
    </plugins>
  </build>
  <profiles>
    <profile>
      <id>pathfuzzer</id>
      <properties>
        <switch.cookiefuzzer.enabled>false</switch.cookiefuzzer.enabled>
        <switch.paramfuzzer.enabled>true</switch.paramfuzzer.enabled>
        <switch.jsonlister.enabled>true</switch.jsonlister.enabled>
        <switch.oobparamfuzzer.enabled>false</switch.oobparamfuzzer.enabled>
        <final.jar.name>pathfuzzer</final.jar.name>
        <switch.paramdeleter.enabled>true</switch.paramdeleter.enabled>
        <netty.port>20808</netty.port>
        <plugin.name>PathFuzzer</plugin.name>
        <context.menu.name>PathFuzzer</context.menu.name>
        <switch.routefuzzer.enabled>true</switch.routefuzzer.enabled>
        <plugin.package.prefix>pzfzr</plugin.package.prefix>
        <shade.package.prefix>pathfuzzer</shade.package.prefix>
        <switch.headerfuzzer.enabled>false</switch.headerfuzzer.enabled>
      </properties>
    </profile>
    <profile>
      <id>oobfuzzer</id>
      <properties>
        <switch.cookiefuzzer.enabled>true</switch.cookiefuzzer.enabled>
        <switch.paramfuzzer.enabled>false</switch.paramfuzzer.enabled>
        <switch.jsonlister.enabled>false</switch.jsonlister.enabled>
        <switch.oobparamfuzzer.enabled>true</switch.oobparamfuzzer.enabled>
        <final.jar.name>oobfuzzer</final.jar.name>
        <switch.paramdeleter.enabled>false</switch.paramdeleter.enabled>
        <netty.port>20668</netty.port>
        <plugin.name>OOBFuzzer</plugin.name>
        <context.menu.name>OOBFuzzer</context.menu.name>
        <switch.routefuzzer.enabled>false</switch.routefuzzer.enabled>
        <plugin.package.prefix>oobfzr</plugin.package.prefix>
        <shade.package.prefix>oobfuzzer</shade.package.prefix>
        <switch.headerfuzzer.enabled>true</switch.headerfuzzer.enabled>
      </properties>
    </profile>
  </profiles>
  <properties>
    <switch.cookiefuzzer.enabled>false</switch.cookiefuzzer.enabled>
    <switch.paramfuzzer.enabled>true</switch.paramfuzzer.enabled>
    <switch.jsonlister.enabled>true</switch.jsonlister.enabled>
    <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
    <switch.oobparamfuzzer.enabled>false</switch.oobparamfuzzer.enabled>
    <maven.compiler.source>17</maven.compiler.source>
    <final.jar.name>pathfuzzer</final.jar.name>
    <switch.paramdeleter.enabled>true</switch.paramdeleter.enabled>
    <netty.port>20808</netty.port>
    <plugin.name>PathFuzzer</plugin.name>
    <context.menu.name>PathFuzzer</context.menu.name>
    <maven.compiler.target>17</maven.compiler.target>
    <switch.routefuzzer.enabled>true</switch.routefuzzer.enabled>
    <plugin.package.prefix>pzfzr</plugin.package.prefix>
    <shade.package.prefix>pathfuzzer</shade.package.prefix>
    <switch.headerfuzzer.enabled>false</switch.headerfuzzer.enabled>
  </properties>
</project>
